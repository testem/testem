{
  "name": "testem",
  "description": "Test'em 'scripts! Javascript Unit testing made easy.",
  "keywords": [
    "javascript",
    "testing",
    "unittest",
    "browser"
  ],
  "version": "3.19.1",
  "author": "Toby Ho <airportyh@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git://github.com/testem/testem.git"
  },
  "bugs": {
    "url": "http://github.com/testem/testem/issues"
  },
  "engines": {
    "node": ">= 7.*"
  },
  "license": "MIT",
  "dependencies": {
    "@xmldom/xmldom": "^0.8.0",
    "backbone": "^1.1.2",
    "charm": "^1.0.0",
    "commander": "^14.0.3",
    "compression": "^1.7.4",
    "consolidate": "^1.0.4",
    "execa": "^9.6.1",
    "express": "^4.10.7",
    "fireworm": "^0.7.2",
    "glob": "^13.0.6",
    "http-proxy": "^1.13.1",
    "js-yaml": "^3.2.5",
    "lodash": "^4.17.21",
    "mkdirp": "^3.0.1",
    "mustache": "^4.2.0",
    "node-notifier": "^10.0.0",
    "printf": "^0.6.1",
    "proc-log": "^5.0.0",
    "rimraf": "^6.1.3",
    "socket.io": "^4.5.4",
    "spawn-args": "^0.2.0",
    "styled_string": "0.0.1",
    "tap-parser": "^7.0.0",
    "tmp": "^0.2.5"
  },
  "files": [
    "lib",
    "public",
    "README.md",
    "testem.js",
    "assets",
    "package.json",
    "views"
  ],
  "scripts": {
    "install:all": "npm install && npm install phantomjs-prebuilt",
    "test": "mocha tests/*_tests.js tests/**/*_tests.js",
    "test:verbose": "TESTEM_VERBOSE=1 mocha tests/*_tests.js tests/**/*_tests.js",
    "cover": "cover run ./node_modules/.bin/_mocha tests/*_tests.js tests/**/*_tests.js; cover report html; open cover_html/index.html",
    "integration": "node ./bin/run-integration.js",
    "browser-tests": "cd examples/saucelabs/ && ../../testem.js ci -d",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@cypress/request": "^3.0.10",
    "@esbuild-plugins/node-modules-polyfill": "^0.2.2",
    "chai": "^6.2.2",
    "chai-files": "^1.2.0",
    "chai-shallow-deep-equal": "^1.4.4",
    "cheerio": "1.0.0-rc.12",
    "dirty-chai": "^3.0.0",
    "esbuild": "^0.25.1",
    "eslint": "^9.39.4",
    "eslint-plugin-chai-expect": "^3.1.0",
    "eslint-plugin-mocha": "^11.2.0",
    "fresh-tape": "^5.5.3",
    "mocha": "^11.7.5",
    "saucie": "^4.0.1",
    "sinon": "^21.0.3",
    "sinon-chai": "^4.0.1",
    "socket.io-client": "^4.1.2"
  },
  "bin": {
    "testem": "./testem.js"
  },
  "main": "./lib/api.js"
}
